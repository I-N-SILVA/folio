# ─── Folio environment ───────────────────────────────────────────────────────
# Copy to .env.local and fill in. Never commit real secrets.

# Public site URL (used for canonical URLs, sitemap, OG, manifest, auth redirect)
NEXT_PUBLIC_SITE_URL=https://folio.new

# ── Supabase ────────────────────────────────────────────────────────────────
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SERVER ONLY. Bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_KEY=your-service-role-key

# ── AppSumo lifetime deal ─────────────────────────────────────────────────────
# API key from the AppSumo partner dashboard. Used to verify webhook signatures
# (HMAC-SHA256 of the raw request body) on /api/appsumo/webhook.
APPSUMO_API_KEY=your-appsumo-api-key

# ── AI (optional) ─────────────────────────────────────────────────────────────
# Google Generative AI key for AI-assisted SEO / copy (see lib/ai.ts)
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Stripe (optional — subscription billing, not required for AppSumo LTD) ─────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PRICE_PRO=
